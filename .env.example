APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Google Sheets
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_API_TIMEOUT_SECONDS=30

# Stored only on the server. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
ENCRYPTED_TOKEN_DIR=./encrypted_tokens

# File outputs for later MVP stages. Sheets only store URLs or review links.
PUBLIC_BASE_URL=http://localhost:8000
LOCAL_STORAGE_DIR=./storage
S3_BUCKET=
S3_REGION=

# Scheduler
SCHEDULER_INTERVAL_SECONDS=300
SERVER_INSTANCE_ID=local-dev
VIDEO_SOURCE_RETENTION_DAYS=14

# SMS abstraction
SMS_PROVIDER=mock
SMS_FORMAT_PATH=./sys_prompts/sms_format.md
SMS_MAX_BYTES=90
NAVER_SENS_ACCESS_KEY=
NAVER_SENS_SECRET_KEY=
NAVER_SENS_SERVICE_ID=
NAVER_SENS_FROM_NUMBER=
NAVER_SENS_TIMEOUT_SECONDS=10

# AI providers. Gemini is the default; Claude is a fallback or per-task override.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE_NAME=Kore
GEMINI_TTS_TIMEOUT_SECONDS=20
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Supertone TTS. Fill these to use Supertone for narration.
SUPERTONE_API_KEY=
SUPERTONE_VOICE_ID=
SUPERTONE_MODEL=sona_speech_2
SUPERTONE_LANGUAGE=ko
SUPERTONE_STYLE=neutral
SUPERTONE_OUTPUT_FORMAT=wav
SUPERTONE_TIMEOUT_SECONDS=30
SUPERTONE_SPEED=0.9

# Optional stock/search/image/video providers can be added behind these adapters later.
IMAGE_PROVIDER=placeholder
TTS_PROVIDER=placeholder
NARRATION_PROVIDER=supertone
NARRATION_ALLOW_SYSTEM_FALLBACK=true
NARRATION_SPEAKING_STYLE=very slow, warm, kind Korean announcer tone
AENEAS_PYTHON_PATH=./aeneas/venv/bin/python
AENEAS_REPO_PATH=./aeneas
AENEAS_LANGUAGE=kor
AENEAS_RUNTIME_CONFIG=tts=macos
AENEAS_TIMEOUT_SECONDS=60
VIDEO_CLIP_PROVIDER=placeholder
MEDIA_SOURCE_MODE=crawl_image
MEDIA_CRAWL_PROVIDER=wikimedia
MEDIA_CRAWL_MAX_RESULTS=32
MEDIA_CRAWL_ALLOWED_LICENSES=cc0,public domain,cc-by,cc-by-sa
MEDIA_CRAWL_TIMEOUT_SECONDS=20
GOOGLE_IMAGE_SEARCH_API_KEY=
GOOGLE_IMAGE_SEARCH_CX=
GOOGLE_IMAGE_SEARCH_RIGHTS=
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Weekly topic count = enabled upload days * this multiplier.
TOPIC_GENERATION_MULTIPLIER=3

# YouTube OAuth, implemented in MVP 4.
GOOGLE_OAUTH_CLIENT_SECRETS=./client_secret.json
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/admin/youtube/oauth/callback
