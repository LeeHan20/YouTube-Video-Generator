APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Google Sheets
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# Stored only on the server. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
ENCRYPTED_TOKEN_DIR=./encrypted_tokens

# File outputs for later MVP stages. Sheets only store URLs or review links.
PUBLIC_BASE_URL=http://localhost:8000
LOCAL_STORAGE_DIR=./storage
S3_BUCKET=
S3_REGION=

# Scheduler
SCHEDULER_INTERVAL_SECONDS=300
SERVER_INSTANCE_ID=local-dev

# SMS abstraction
SMS_PROVIDER=mock
